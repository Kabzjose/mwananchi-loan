      "parameters": {
        "jsCode": "return [{\n  status: \"Human Review Required\",\n  applicant: $json.applicant,\n  amount: $json.amount,\n  reason: \"Loan exceeds KES 15,000 limit\",\n  approved: false,        // add this\n  escalated: true\n}];"
      },
