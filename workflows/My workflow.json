    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const applicant = Object.assign({}, $json.applicant || {});\n\nconst sensitiveFields = ['gender', 'ethnicity', 'race', 'religion'];\nsensitiveFields.forEach(field => {\n  if(field in applicant){\n    delete applicant[field];\n  }\n});\n\nreturn {\n  applicant,\n  amount: $json.amount,\n  approved: true,\n  escalated: false,\n  status: \"Bias Safe\"\n};"
      },
