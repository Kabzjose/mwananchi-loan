      "id": "89c599c1-50ef-42f3-abf4-c290fd815b54",
      "name": "HUNT Handoff"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const amount = Number($json.amount);\n\nlet riskFlags = 0;\n\nif(amount > 15000){\n riskFlags++;\n}\n\nreturn {\n amount,\n riskFlags,\n escalate: amount > 15000,\n applicant: $json.applicant\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
