    },
    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\n\nconst text = body.message || \"\";\nconst applicant = body.applicant;\nconst amount = body.amount;\n\nconst stressWords = [\n  \"school fees\",\n  \"loan shark\",\n  \"no money\",\n  \"can't pay\",\n  \"struggling\"\n];\n\nconst detected = stressWords.some(word =>\n  text.toLowerCase().includes(word)\n);\n\nreturn [{\n  financialStress: detected,\n  message: text,\n  applicant: applicant,\n  amount: amount\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
      ],
      "id": "873440e4-3924-4891-8d69-6a9c87a291d0",
      "name": "Scout Agent"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 3
          },
          "conditions": [
            {
              "id": "fd1242a4-6faf-4281-bb1c-ec5f9f00cb6d",
              "leftValue": "={{ $json.financialStress }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "looseTypeValidation": true,
        "options": {}
      },
      "type": "n8n-nodes-base.if",
